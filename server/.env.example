# DeepSeek API
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# DeepSeek 费用估算（元/百万 Token）
DEEPSEEK_INPUT_PRICE_PER_M=1.0
DEEPSEEK_OUTPUT_PRICE_PER_M=2.0

# 应用环境: development | production
APP_ENV=production

# 站点信息（隐私政策/用户协议中的联系方式）
SITE_URL=https://wenhaode.com
CONTACT_EMAIL=support@wenhaode.com

# API 鉴权（production 建议 true）
API_AUTH_ENABLED=true

# 环境变量 API Key（格式: 标签:日限额:key 或纯 key，多个逗号分隔）
# 示例: 内测:100:wh_xxx,公开:50:wh_yyy
API_KEYS=

# 管理后台 Token（访问 /stats 和 /api/stats/*）
ADMIN_TOKEN=change-me-to-a-long-random-string

# 默认每 Key 日调用上限（analyze + complete 各计 1 次）
DEFAULT_DAILY_LIMIT=100
GLOBAL_DAILY_LIMIT=50000

# CORS（生产环境建议指定域名，* 表示允许所有）
CORS_ORIGINS=*

# 是否开放 /docs（生产建议 false）
DOCS_ENABLED=false

# MySQL 数据库
DB_HOST=mysql
DB_PORT=3306
DB_NAME=aihelper
DB_USER=aihelper
DB_PASSWORD=change-me

# MOCK_AI=1
