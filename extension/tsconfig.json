{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "types": ["chrome", "vite/client"],
    "paths": {
      "@aihelper/requirement": ["../packages/requirement/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../packages/requirement/src/**/*"]
}
