{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "问得好",
  "version": "1.0.0",
  "identifier": "com.wenhaode.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "问得好 PC 伴侣",
        "width": 420,
        "height": 760,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "AI 提问增强 PC 伴侣",
    "longDescription": "在 ChatGPT / DeepSeek 桌面客户端中复制问题，一键优化并复制回剪贴板。"
  }
}
